generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Shop {
  id           String        @id @default(cuid())
  name         String
  ledgerDays   LedgerDay[]
  ledgerMonths LedgerMonth[]

  @@map("shops")
}

model Category {
  id                 String                @id @default(cuid())
  name               String
  color              String?
  order              Int                   @default(0)
  categoryMargins   CategoryMargin[]
  products          Product[]

  @@map("categories")
}

model Ingredient {
  id      String       @id @default(cuid())
  name    String
  price   Float?
  unit    String?
  order   Int          @default(0)
  recipes RecipeItem[]

  @@map("ingredients")
}

model Product {
  id             String       @id @default(cuid())
  name           String
  manualCost     Float        @default(0) @map("manual_cost")
  storePrice     Float        @default(0) @map("store_price")
  onlinePrice    Float        @default(0) @map("online_price")
  order          Int          @default(0)
  categoryId     String?      @map("category_id")
  category       Category?    @relation(fields: [categoryId], references: [id])
  recipe         RecipeItem[]
  usedInRecipes  RecipeItem[] @relation("SubProductRecipes")
  costHistory    ProductCostHistory[]
  costSources    ProductCostSource[]

  @@map("products")
}

model ProductCostSource {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  sourceName String   @map("source_name")
  cost       Float
  isSelected Boolean  @default(false) @map("is_selected")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_cost_sources")
}

model ProductCostHistory {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  dateKey   String   @map("date_key")
  cost      Float
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, dateKey])
  @@map("product_cost_history")
}

model RecipeItem {
  id           String      @id @default(cuid())
  productId    String      @map("product_id")
  ingredientId String?     @map("ingredient_id")
  subProductId String?     @map("sub_product_id")
  quantity     Float
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  subProduct   Product?    @relation("SubProductRecipes", fields: [subProductId], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("recipe_items")
}

model Margin {
  id                String                @id @default(cuid())
  name              String?
  value             Float
  type              String
  commissionRate    Float?           @map("commission_rate")
  categorySpecifics CategoryMargin[]

  @@map("margins")
}

model CategoryMargin {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  marginId   String   @map("margin_id")
  value      Float
  margin     Margin   @relation(fields: [marginId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, marginId])
  @@map("category_margins")
}

model GlobalSettings {
  id                    String @id @default("default")
  kdvRate               Float  @default(10) @map("kdv_rate")
  bankCommissionRate    Float  @default(4) @map("bank_commission_rate")
  stopajRate            Float  @default(1) @map("stopaj_rate")
  migrosCommission      Float  @default(40) @map("migros_commission")
  getirCommission       Float  @default(40) @map("getir_commission")
  yemeksepetiCommission Float  @default(40) @map("yemeksepeti_commission")
  trendyolCommission    Float  @default(40) @map("trendyol_commission")

  // Prices page simulated commissions
  platformCommission    Float  @default(40) @map("platform_commission")
  pricesMigrosCommission      Float? @map("prices_migros_commission")
  pricesGetirCommission       Float? @map("prices_getir_commission")
  pricesYemeksepetiCommission Float? @map("prices_yemeksepeti_commission")
  pricesTrendyolCommission    Float? @map("prices_trendyol_commission")

  @@map("global_settings")
}

model LedgerMonth {
  id           String      @id @default(cuid())
  shopId       String      @map("shop_id")
  monthKey     String      @map("month_key")
  rent         Float?      @default(0)
  electricity  Float?      @default(0)
  water        Float?      @default(0)
  accounting   Float?      @default(0)
  ads          Float?      @default(0)
  shopMargin   Float?      @default(0) @map("shop_margin")
  migrosProfit Float?      @default(0) @map("migros_profit")
  getirProfit  Float?      @default(0) @map("getir_profit")
  yemeksepetiProfit Float? @default(0) @map("yemeksepeti_profit")
  trendyolProfit Float?    @default(0) @map("trendyol_profit")
  extraCosts   ExtraCost[]
  shop         Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, monthKey])
  @@map("ledger_months")
}

model LedgerDay {
  id               String   @id @default(cuid())
  shopId           String   @map("shop_id")
  date             DateTime
  cash             Float?   @default(0)
  pos              Float?   @default(0)
  mealCard         Float?   @default(0) @map("meal_card")
  kg               Float?   @default(0)
  migrosCount      Int?     @default(0) @map("migros_count")
  migrosRev        Float?   @default(0) @map("migros_rev")
  getirCount       Int?     @default(0) @map("getir_count")
  getirRev         Float?   @default(0) @map("getir_rev")
  yemeksepetiCount Int?     @default(0) @map("yemeksepeti_count")
  yemeksepetiRev   Float?   @default(0) @map("yemeksepeti_rev")
  trendyolCount    Int?     @default(0) @map("trendyol_count")
  trendyolRev      Float?   @default(0) @map("trendyol_rev")
  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, date])
  @@map("ledger_days")
}

model ExtraCost {
  id            String      @id @default(cuid())
  ledgerMonthId String      @map("ledger_month_id")
  name          String
  amount        Float
  ledgerMonth   LedgerMonth @relation(fields: [ledgerMonthId], references: [id], onDelete: Cascade)

  @@map("extra_costs")
}

model MealCardInvoice {
  id          String   @id @default(cuid())
  invoiceDate String   @map("invoice_date")
  platform    String
  completed   Boolean  @default(false)

  @@unique([invoiceDate, platform])
  @@index([invoiceDate])
  @@map("meal_card_invoices")
}
